---
import BaseLayout from "../layouts/BaseLayout.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import { getTarifs, getFaqs } from "../lib/backend.mjs";

const tarifs = await getTarifs();
const faqs = await getFaqs();

const hebergements = [
  {
    title: "Camping du Festival",
    text: "Profitez de notre camping officiel situé à 5 minutes à pied du site du festival. Sanitaires, douches chaudes et food trucks sur place.",
    price: "20€ / nuit",
  },
  {
    title: "Hôtels Partenaires",
    text: "Bénéficiez de tarifs préférentiels dans nos hôtels partenaires à Belfort. Navettes gratuites vers le festival.",
    price: "À partir de 65€ / nuit",
  },
  {
    title: "Locations Saisonnières",
    text: "Découvrez notre sélection d'appartements et maisons à louer à proximité du festival.",
    price: "Tarifs variables",
  },
];

const transports = [
  {
    title: "En Train",
    text: "Gare de Belfort à 10 minutes en navette gratuite du festival. TGV directs depuis Paris, Lyon et Strasbourg.",
    symbol: "🚆",
  },
  {
    title: "En Voiture",
    text: "Parkings gratuits disponibles. Suivre direction « Berges de la Savoureuse ». Covoiturage encouragé avec places réservées.",
    symbol: "🚗",
  },
  {
    title: "Navettes",
    text: "Navettes gratuites depuis la gare, le centre-ville et les hôtels partenaires. Circulation toutes les 15 minutes.",
    symbol: "🚌",
  },
];
---

<BaseLayout
  title="Infos pratiques | Les Rives du Territoire"
  description="Toutes les informations pour préparer votre venue."
>
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6 md:py-20">
    <h1 class="font-mono text-5xl font-bold text-white md:text-7xl">
      Infos Pratiques
    </h1>

    <p class="mt-5 max-w-3xl text-lg leading-8 text-white/80 md:text-2xl">
      Toutes les informations pour préparer votre venue
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-6">
    <h2 class="font-mono text-3xl font-bold text-white md:text-4xl">
      Tarifs & Billetterie
    </h2>

    {
      tarifs.length > 0 ? (
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {tarifs.map((tarif) => (
            <article class="rounded-[24px] border border-white/10 bg-[#222b3b] p-7">
              <h3 class="font-mono text-2xl font-bold text-white">
                {tarif.nom_tarif}
              </h3>

              <p class="mt-4 text-4xl font-bold text-[#facc15]">
                {tarif.prix}€
              </p>

              <ul class="mt-5 space-y-2 text-sm leading-7 text-white/75">
                {tarif.description
                  ?.split("\n")
                  .filter(Boolean)
                  .map((line) => (
                    <li>• {line}</li>
                  ))}
              </ul>

              <div class="mt-6">
                <a
                  href="#"
                  class="inline-flex items-center justify-center rounded-full bg-[#7c3aed] px-6 py-2.5 text-sm font-semibold text-white transition hover:opacity-90"
                >
                  Acheter
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="mt-8 rounded-[24px] border border-white/10 bg-[#222b3b] p-8 text-white/70">
          Aucun tarif disponible pour le moment.
        </div>
      )
    }
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-6">
    <h2 class="font-mono text-3xl font-bold text-white md:text-4xl">
      Hébergements
    </h2>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        hebergements.map((item) => (
          <article class="rounded-[12px] border border-white/10 bg-[#222b3b] p-7">
            <h3 class="font-mono text-2xl font-bold text-white">
              {item.title}
            </h3>

            <p class="mt-5 text-sm leading-7 text-white/75">{item.text}</p>

            <p class="mt-5 text-sm font-semibold text-[#facc15]">
              {item.price}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-6 bg-white">
    <h2 class="font-mono text-3xl font-bold text-black md:text-4xl">
      Comment venir
    </h2>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        transports.map((item) => (
          <article class="rounded-[24px]  p-7 text-center">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-white text-3xl">
              {item.symbol}
            </div>

            <h3 class="mt-5 font-mono text-2xl font-bold text-white">
              {item.title}
            </h3>

            <p class="mt-4 text-sm leading-7 text-white/75">{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-6 bg-white">
    <h2 class="font-mono text-3xl font-bold text-black md:text-4xl">
      Questions Fréquentes
    </h2>

    <div class="mt-10">
      {
        faqs.length > 0 ? (
          <FaqAccordion items={faqs} />
        ) : (
          <div class="rounded-[24px] border border-white/10 bg-[#222b3b] p-8 text-white/70">
            Aucune question fréquente disponible pour le moment.
          </div>
        )
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-6">
    <div
      class="rounded-[28px] border border-white/10 bg-[#222b3b] px-6 py-12 text-center md:px-12"
    >
      <h2 class="font-mono text-4xl font-bold text-white md:text-5xl">
        Prêt pour l’aventure ?
      </h2>

      <p
        class="mx-auto mt-6 max-w-3xl text-base leading-8 text-white/80 md:text-xl"
      >
        Toutes les informations sont réunies, il ne vous reste plus qu’à
        réserver vos billets
      </p>

      <div class="mt-8">
        <a
          href="#"
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-base font-semibold text-[#7c3aed] transition hover:opacity-90"
        >
          Acheter vos billets maintenant
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
