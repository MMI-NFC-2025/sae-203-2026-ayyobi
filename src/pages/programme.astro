---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProgramCard from '../components/ProgramCard.astro';
import { getProgrammation } from '../lib/backend.mjs';

const programme = await getProgrammation();
---

<BaseLayout title="Programme" description="Programme du festival">
  <Hero
    title="Programme"
    subtitle="Tous les passages, scenes et artistes du festival."
  />

  <section class="mx-auto w-full max-w-6xl px-4 py-8">
    <div class="grid gap-4">
      {programme.map((item) => <ProgramCard item={item} />)}
    </div>
  </section>
</BaseLayout>
