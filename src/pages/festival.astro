---
import BaseLayout from "../layouts/BaseLayout.astro";
import TeamCard from "../components/TeamCard.astro";
import { getTeam } from "../lib/backend.mjs";

const team = await getTeam();

const values = [
  {
    title: "Créativité",
    text: "Encourager l'expression artistique sous toutes ses formes, mettre en avant les jeunes talents locaux et émergents.",
    bgClass: "bg-[#f0045a]",
    icon: "heart",
  },
  {
    title: "Éco-responsabilité",
    text: "Notre engagement pour l'environnement se traduit par des actions concrètes : tri des déchets, gobelets réutilisables, et partenaires locaux.",
    bgClass: "bg-[#08a651]",
    icon: "leaf",
  },
  {
    title: "Convivialité",
    text: "Nous créons un espace de partage et de rencontre où règnent bienveillance, inclusion et moments festifs inoubliables.",
    bgClass: "bg-[linear-gradient(180deg,#8b2cf5_0%,#f0047f_100%)]",
    icon: "users",
  },
];
---

<BaseLayout
  title="Le Festival | Les Rives du Territoire"
  description="Découvrez l’histoire et les valeurs du festival Les Rives du Territoire."
>
  <section class="border-b border-white/10 bg-[#1b2230]">
    <div class="mx-auto max-w-7xl px-4 py-16 text-center md:px-6 md:py-24">
      <h1 class="font-mono text-5xl font-bold text-white md:text-7xl">
        Le Festival
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-white/80 md:text-2xl">
        Découvrez l’histoire et les valeurs de Les Rives du Territoire.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6 bg-white">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div>
        <h2 class="font-mono text-4xl font-bold text-black md:text-5xl">
          Notre Histoire
        </h2>

        <div
          class="mt-8 space-y-6 text-base leading-8 text-black/75 md:text-lg"
        >
          <p>
            Créé en 2020, le festival Les Rives du Territoire est né de la
            volonté de célébrer la diversité culturelle et musicale du
            Territoire. Installé sur les magnifiques berges de la Savoureuse à
            Belfort, notre festival est devenu un rendez-vous incontournable
            pour les amoureux de musique et de culture urbaine.
          </p>

          <p>
            Chaque année, nous accueillons des milliers de festivaliers venus
            découvrir des artistes émergents et confirmés dans une ambiance
            unique et conviviale. Notre objectif est de créer un espace de
            partage et de découverte où la musique rassemble les frontières.
          </p>
        </div>
      </div>

      <div
        class="overflow-hidden rounded-[28px]  bg-[#222b3b]"
      >
        <img
          src="/images/festival-history.jpg"
          alt="Public du festival"
          class="aspect-[4/3] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <section class="bg-[#182030]">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-6">
      <div class="max-w-3xl">
        <h2 class="font-mono text-4xl font-bold text-white md:text-5xl">
          Notre équipe
        </h2>
        <p class="mt-4 text-base leading-8 text-white/75 md:text-lg">
          Une équipe passionnée au service de votre expérience festivalière.
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {team.map((member) => <TeamCard member={member} />)}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6 bg-white">
    <div class="max-w-3xl">
      <h2 class="font-mono text-4xl font-bold text-black md:text-5xl">
        Nos valeurs
      </h2>
      <p class="mt-4 text-base leading-8 text-black/75 md:text-lg">
        Une vision artistique ouverte, humaine et responsable.
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        values.map((value) => (
          <article class="rounded-[24px]  p-6 text-center">
            <div class={`mx-auto flex h-20 w-20 items-center justify-center rounded-2xl text-white ${value.bgClass}`}>
              {value.icon === "heart" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  class="h-10 w-10"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 21s-6.716-4.35-9.193-8.205C.84 9.73 1.396 5.72 4.62 4.05 7.008 2.813 9.59 3.78 11.01 5.57L12 6.82l.99-1.25c1.42-1.79 4.002-2.757 6.39-1.52 3.224 1.67 3.78 5.68 1.813 8.745C18.716 16.65 12 21 12 21Z"
                  />
                </svg>
              )}
              {value.icon === "leaf" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  class="h-10 w-10"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 5c-4.5 0-7.438 1.375-9.25 3.188C7.938 10 7 12.5 7 15c0 1.488.335 2.845.92 4"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 5c0 8.5-4 13-10.5 13-1.3 0-2.453-.14-3.5-.438"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 19c2.5-4.5 6.167-7.5 11-9"
                  />
                </svg>
              )}
              {value.icon === "users" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  class="h-10 w-10"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8.5 11a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.5 12a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.5 19.5v-1c0-2.761 2.239-5 5-5h1c2.761 0 5 2.239 5 5v1"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M14 19.5v-.5c0-2.485 2.015-4.5 4.5-4.5h.5c.552 0 1 .448 1 1v4"
                  />
                </svg>
              )}
            </div>

            <h3 class="mt-5 font-mono text-2xl font-bold text-black">
              {value.title}
            </h3>

            <p class="mt-4 text-sm leading-7 text-black/70">{value.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="border-t border-white/10 bg-[#182030]">
    <div class="mx-auto max-w-7xl px-4 py-16 text-center md:px-6">
      <h2 class="font-mono text-4xl font-bold text-white md:text-5xl">
        Rejoignez l’aventure
      </h2>

      <p
        class="mx-auto mt-6 max-w-3xl text-base leading-8 text-white/80 md:text-xl"
      >
        Vivez une expérience unique sur les Rives du Territoire du 20 au 23
        décembre 2026.
      </p>

      <div class="mt-8">
        <a
          href="/infos-pratiques"
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-base font-semibold text-[#7c3aed] transition hover:opacity-90"
        >
          Acheter vos billets maintenant
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
