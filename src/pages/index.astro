---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArtistCard from '../components/ArtistCard.astro';
import SceneCard from '../components/SceneCard.astro';
import ProgramCard from '../components/ProgramCard.astro';
import { getArtistes, getScenes, getProgrammation } from '../lib/backend.mjs';

const [artists, scenes, programme] = await Promise.all([
  getArtistes(),
  getScenes(),
  getProgrammation(),
]);
---

<BaseLayout title="Festival | Accueil" description="Accueil du festival">
  <Hero
    title="Les voix et les scenes du territoire"
    subtitle="Retrouve les artistes, le programme et toutes les informations utiles du festival."
  />

  <section class="mx-auto grid w-full max-w-6xl gap-12 px-4 py-8">
    <div>
      <h2 class="text-2xl font-black">Artistes</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {artists.slice(0, 3).map((artist) => <ArtistCard artist={artist} />)}
      </div>
    </div>

    <div>
      <h2 class="text-2xl font-black">Scenes</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {scenes.slice(0, 3).map((scene) => <SceneCard scene={scene} />)}
      </div>
    </div>

    <div>
      <h2 class="text-2xl font-black">Programme</h2>
      <div class="mt-6 grid gap-4">
        {programme.slice(0, 3).map((item) => <ProgramCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
