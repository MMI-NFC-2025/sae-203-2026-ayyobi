---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PocketImage from "../components/PocketImage.astro";
import { getPartners } from "../lib/backend.mjs";

const partners = await getPartners();

const keyDates = [
  {
    day: "20 décembre",
    text: "Ouverture des portes",
  },
  {
    day: "21 décembre",
    text: "Jour 2 - Programme complet",
  },
  {
    day: "22 décembre",
    text: "Jour 3 - Artistes phares",
  },
  {
    day: "23 décembre",
    text: "Clôture du festival",
  },
];

const homeCards = [
  {
    title: "Le Festival",
    text: "Découvrez l’histoire et les valeurs de Les Rives du Territoire.",
    href: "/festival",
    image: "/images/festival-card.jpg",
  },
  {
    title: "Programme",
    text: "Découvrez le programme complet du festival avec tous les artistes et horaires.",
    href: "/programme",
    image: "/images/programme-card.jpg",
  },
  {
    title: "Les Artistes",
    text: "Découvrez les talents qui animeront le festival.",
    href: "/artistes",
    image: "/images/artistes-card.jpg",
  },
  {
    title: "Contact",
    text: "Une question ? Contactez-nous.",
    href: "/contact",
    image: "/images/contact-card.jpg",
  },
];
---

<BaseLayout
  title="Accueil | Les Rives du Territoire"
  description="Festival musical et culturel Les Rives du Territoire"
>
  <Hero
    title="Les Rives du Territoire"
    subtitle="Ensemble, vibrons au rythme du territoire."
    buttonText="Réserver vos billets"
    buttonHref="#tarifs-fictif"
    image="/images/hero-home.jpg"
    dates={keyDates}
  />

  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6">
    <div class="grid gap-8 md:grid-cols-2">
      {
        homeCards.map((card) => (
          <a
            href={card.href}
            class="group relative block overflow-hidden rounded-[26px] border border-white/10 bg-[#222b3b]"
          >
            <img
              src={card.image}
              alt={card.title}
              class="h-72 w-full object-cover transition duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1b2230] via-[#1b2230]/55 to-transparent"></div>

            <div class="absolute inset-x-0 bottom-0 p-6">
              <h2 class="font-mono text-3xl font-bold text-white">
                {card.title}
              </h2>
              <p class="mt-3 max-w-md text-sm leading-6 text-white/80">
                {card.text}
              </p>
              <span class="mt-4 inline-block text-sm font-semibold text-[#a855f7]">
                Découvrir →
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="border-y border-white/10 bg-[#182030]">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-6">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="font-mono text-4xl font-bold text-white md:text-5xl">
          Nos partenaires
        </h2>
      </div>

      <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-6">
        {
          partners.map((partner) => (
            <a
              href={partner.site_web}
              target="_blank"
              rel="noreferrer"
              class="flex min-h-[110px] items-center justify-center rounded-[18px] border border-white/10 bg-[#222b3b] p-4 transition hover:border-white/20 hover:bg-white/5"
            >
              <PocketImage
                record={partner}
                field="logo"
                alt={partner.nom}
                class="max-h-14 max-w-14 object-contain"
              />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="tarifs-fictif" class="mx-auto max-w-7xl px-4 py-16 md:px-6">
    <div class="rounded-[28px] bg-[#222b3b] px-6 py-12 text-center md:px-12">
      <h2 class="font-mono text-4xl font-bold text-white md:text-5xl">
        Prêt à vibrer au rythme du territoire ?
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-base leading-8 text-white/80 md:text-xl">
        Rejoignez-nous du 20 au 23 décembre 2026 aux Berges de la Savoureuse à
        Belfort pour une expérience inoubliable de musique, art et culture urbaine.
      </p>

      <div class="mt-8">
        <a
          href="/infos-pratiques"
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-base font-semibold text-[#7c3aed] transition hover:opacity-90"
        >
          Acheter vos billets maintenant
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
