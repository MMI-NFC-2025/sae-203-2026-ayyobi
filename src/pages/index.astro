---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Accueil | Les Rives du Territoire">
  <section class="mx-auto max-w-7xl px-4 py-16">
    <div class="rounded-[28px] border border-white/10 bg-white/5 p-8 md:p-12">
      <h1 class="text-4xl font-bold md:text-6xl">Les Rives du Territoire</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-white/75 md:text-lg">
        Ensemble, vibrons au rythme du territoire.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/programme"
          class="inline-flex items-center justify-center rounded-full bg-[#facc15] px-6 py-3 font-semibold text-black transition hover:opacity-90"
        >
          Voir le programme
        </a>

        <a
          href="/artistes"
          class="inline-flex items-center justify-center rounded-full border border-white/15 px-6 py-3 font-semibold text-white transition hover:bg-white/5"
        >
          Découvrir les artistes
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
