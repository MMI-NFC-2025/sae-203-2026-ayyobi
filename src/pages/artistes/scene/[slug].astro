---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArtistCard from "../../../components/ArtistCard.astro";
import {
  getScenes,
  getSceneById,
  getSceneBySlug,
  getArtistsBySceneId,
} from "../../../lib/backend.mjs";
import { slugify } from "../../../lib/utils.mjs";

export const prerender = true;

export async function getStaticPaths() {
  const scenes = await getScenes();

  return scenes.flatMap((scene) => [
    { params: { slug: slugify(scene.nom_scene) } },
    { params: { slug: scene.id } },
  ]);
}

const { slug } = Astro.params;

let scene = await getSceneBySlug(slug);

if (!scene) {
  const sceneById = await getSceneById(slug);

  if (sceneById) {
    return Astro.redirect(`/artistes/scene/${slugify(sceneById.nom_scene)}`);
  }

  throw new Error("Scene introuvable");
}

const artists = await getArtistsBySceneId(scene.id);
---

<BaseLayout
  title={`${scene.nom_scene} | Les Rives du Territoire`}
  description={`Decouvrez les artistes programmes sur ${scene.nom_scene}.`}
>
  <section class="border-b border-white/10 bg-[#1b2230]">
    <div class="mx-auto max-w-7xl px-4 py-16 text-center md:px-6 md:py-24">
      <p
        class="text-sm font-semibold uppercase tracking-[0.2em] text-[#facc15]"
      >
        Filtre par scene
      </p>

      <h1 class="mt-4 font-mono text-5xl font-bold text-white md:text-7xl">
        {scene.nom_scene}
      </h1>

      {
        scene.description_scene && (
          <p class="mx-auto mt-6 max-w-3xl text-center text-lg leading-8 text-white/80 md:text-2xl">
            {scene.description_scene}
          </p>
        )
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6">
    {
      artists.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {artists.map((item) => (
            <ArtistCard item={item} />
          ))}
        </div>
      ) : (
        <div class="rounded-[24px] border border-white/10 bg-[#222b3b] p-8 text-center text-white/70">
          Aucun artiste trouve pour cette scene.
        </div>
      )
    }
  </section>
</BaseLayout>
