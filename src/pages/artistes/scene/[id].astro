---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import ArtistCard from "../../../../components/ArtistCard.astro";
import {
  getScenes,
  getSceneById,
  getArtistsBySceneId,
} from "../../../../lib/backend.mjs";

export async function getStaticPaths() {
  const scenes = await getScenes();

  return scenes.map((scene) => ({
    params: { id: scene.id },
  }));
}

const { id } = Astro.params;
const scene = await getSceneById(id);
const artists = await getArtistsBySceneId(id);
---

<BaseLayout
  title={`${scene.nom_scene} | Les Rives du Territoire`}
  description={`Découvrez les artistes programmés sur ${scene.nom_scene}.`}
>
  <section class="border-b border-white/10 bg-[#1b2230]">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-6 md:py-24">
      <p
        class="text-sm font-semibold uppercase tracking-[0.2em] text-[#facc15]"
      >
        Filtre par scène
      </p>

      <h1 class="mt-4 font-mono text-5xl font-bold text-white md:text-7xl">
        {scene.nom_scene}
      </h1>

      {
        scene.description_scene && (
          <p class="mt-6 max-w-3xl text-lg leading-8 text-white/80 md:text-2xl">
            {scene.description_scene}
          </p>
        )
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6">
    {
      artists.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {artists.map((item) => (
            <ArtistCard item={item} />
          ))}
        </div>
      ) : (
        <div class="rounded-[24px] border border-white/10 bg-[#222b3b] p-8 text-center text-white/70">
          Aucun artiste trouvé pour cette scène.
        </div>
      )
    }
  </section>
</BaseLayout>
