---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PocketImage from "../../components/PocketImage.astro";
import {
  getArtists,
  getArtistById,
  getGalleryUrls,
  getProgramByArtistId,
} from "../../lib/backend.mjs";
import { formatDate, formatHour } from "../../lib/utils.mjs";

export async function getStaticPaths() {
  const artists = await getArtists();

  return artists.map((artist) => ({
    params: { id: artist.id },
  }));
}

const { id } = Astro.params;

const artist = await getArtistById(id);
const programs = await getProgramByArtistId(id);
const gallery = getGalleryUrls(artist, "galerie_photos");
---

<BaseLayout
  title={`${artist.nom_artiste} | Les Rives du Territoire`}
  description={artist.description}
>
  <section class="border-b border-white/10 bg-[#1b2230]">
    <div class="mx-auto max-w-7xl px-4 py-16 text-center md:px-6 md:py-24">
      <p
        class="text-sm font-semibold uppercase tracking-[0.2em] text-[#facc15]"
      >
        Artiste
      </p>

      <h1 class="mt-4 font-mono text-5xl font-bold text-white md:text-7xl">
        {artist.nom_artiste}
      </h1>

      {
        artist.genre_musical && (
          <p class="mt-6 text-lg leading-8 text-white/80 md:text-2xl">
            {artist.genre_musical}
          </p>
        )
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6">
    <div class="grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-start">
      <div
        class="overflow-hidden rounded-[28px] border border-white/10 bg-[#222b3b]"
      >
        <PocketImage
          record={artist}
          field="photo_principale"
          alt={artist.nom_artiste}
          class="aspect-[4/5] w-full object-cover object-top"
        />
      </div>

      <div>
        <h2 class="font-mono text-3xl font-bold text-white md:text-4xl">
          À propos
        </h2>

        <p class="mt-6 text-base leading-8 text-white/75 md:text-lg">
          {artist.description}
        </p>

        <div class="mt-10">
          <h3 class="font-mono text-2xl font-bold text-white">
            Dates de représentation
          </h3>

          {
            programs.length > 0 ? (
              <div class="mt-6 space-y-4">
                {programs.map((item) => (
                  <article class="rounded-[20px] border border-white/10 bg-[#222b3b] p-5">
                    <p class="font-mono text-xl font-bold text-[#facc15]">
                      {formatDate(item.date_representation)}
                    </p>
                    <p class="mt-2 text-sm text-white/75">
                      {formatHour(item.date_representation)}
                    </p>
                    <p class="mt-2 text-sm font-semibold text-white">
                      {item.expand?.scene?.nom_scene}
                    </p>
                  </article>
                ))}
              </div>
            ) : (
              <p class="mt-4 text-white/60">Aucune date disponible.</p>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-6">
    <h2 class="font-mono text-3xl font-bold text-white md:text-4xl">
      Galerie photo
    </h2>

    {
      gallery.length > 0 ? (
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {gallery.map((imageUrl, index) => (
            <div class="overflow-hidden rounded-[22px] border border-white/10 bg-[#222b3b]">
              <img
                src={imageUrl}
                alt={`${artist.nom_artiste} - photo ${index + 1}`}
                class="aspect-[4/3] w-full object-cover object-top"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="mt-6 rounded-[22px] border border-white/10 bg-[#222b3b] p-6 text-white/60">
          Aucune galerie photo disponible.
        </div>
      )
    }
  </section>
</BaseLayout>
