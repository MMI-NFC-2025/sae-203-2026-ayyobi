---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PocketImage from '../../components/PocketImage.astro';
import ProgramCard from '../../components/ProgramCard.astro';
import { getArtistes, getArtiste, getProgrammationParArtiste } from '../../lib/backend.mjs';

export async function getStaticPaths() {
  const artists = await getArtistes();
  return artists.map((artist) => ({ params: { id: artist.id } }));
}

const { id } = Astro.params;
const [artist, programme] = await Promise.all([
  getArtiste(id),
  getProgrammationParArtiste(id),
]);
---

<BaseLayout title={artist.nom} description={artist.description || artist.nom}>
  <section class="mx-auto grid w-full max-w-6xl gap-8 px-4 py-12 lg:grid-cols-[1fr_1fr]">
    <div class="overflow-hidden rounded-[2rem] bg-slate-100">
      <PocketImage src={artist.photo} alt={artist.nom} className="aspect-[4/3]" />
    </div>
    <div>
      <p class="text-sm uppercase tracking-[0.2em] text-slate-500">{artist.genre}</p>
      <h1 class="mt-3 text-4xl font-black">{artist.nom}</h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600">{artist.description}</p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-12">
    <h2 class="text-2xl font-black">Passages</h2>
    <div class="mt-6 grid gap-4">
      {programme.map((item) => <ProgramCard item={item} />)}
    </div>
  </section>
</BaseLayout>
