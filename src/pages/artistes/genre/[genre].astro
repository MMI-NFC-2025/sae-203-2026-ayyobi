---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArtistCard from '../../../components/ArtistCard.astro';
import { getArtistes } from '../../../lib/backend.mjs';

export async function getStaticPaths() {
  const artists = await getArtistes();
  const genres = [...new Set(artists.map((artist) => artist.genreSlug).filter(Boolean))];
  return genres.map((genre) => ({ params: { genre } }));
}

const { genre } = Astro.params;
const artists = (await getArtistes()).filter((artist) => artist.genreSlug === genre);
---

<BaseLayout title="Artistes par genre" description="Liste des artistes par genre">
  <section class="mx-auto w-full max-w-6xl px-4 py-12">
    <h1 class="text-4xl font-black">Genre : {genre}</h1>
    <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {artists.map((artist) => <ArtistCard artist={artist} />)}
    </div>
  </section>
</BaseLayout>
