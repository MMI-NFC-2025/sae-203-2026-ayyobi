---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SceneCard from '../../components/SceneCard.astro';
import { getScenes } from '../../lib/backend.mjs';

const scenes = await getScenes();
---

<BaseLayout title="Scenes" description="Toutes les scenes du festival">
  <Hero title="Scenes" subtitle="Decouvre les espaces du festival et leurs ambiances." />

  <section class="mx-auto w-full max-w-6xl px-4 py-8">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {scenes.map((scene) => <SceneCard scene={scene} />)}
    </div>
  </section>
</BaseLayout>
