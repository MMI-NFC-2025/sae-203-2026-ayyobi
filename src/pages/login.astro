---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Login" description="Connexion festival">
  <section class="mx-auto w-full max-w-xl px-4 py-16">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
      <h1 class="text-center text-3xl font-black">Connexion</h1>
      <form class="mt-8 grid gap-4">
        <input type="email" placeholder="Email" class="rounded-xl border border-slate-300 px-4 py-3" />
        <input type="password" placeholder="Mot de passe" class="rounded-xl border border-slate-300 px-4 py-3" />
        <button type="submit" class="rounded-full bg-slate-950 px-5 py-3 text-sm font-bold text-white">
          Se connecter
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
