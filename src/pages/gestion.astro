---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Gestion | Les Rives du Territoire"
  description="Ajoutez ou modifiez les artistes et les scenes du festival."
>
  <section class="border-b border-white/10 bg-[#1b2230]">
    <div class="mx-auto max-w-7xl px-4 py-16 text-center md:px-6 md:py-20">
      <h1 class="font-mono text-5xl font-bold text-white md:text-7xl">
        Espace de gestion
      </h1>

      <p
        class="mx-auto mt-5 max-w-3xl text-lg leading-8 text-white/80 md:text-2xl"
      >
        Depuis cette page, vous pouvez ajouter ou modifier les artistes et les
        scenes du festival.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6">
    <div class="rounded-[24px] border border-white/10 bg-[#222b3b] p-6 md:p-8">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.2em] text-[#facc15]"
          >
            Session
          </p>
          <p id="authStatus" class="mt-2 text-white/80">
            Verification de la session...
          </p>
        </div>

        <button
          id="logoutButton"
          type="button"
          class="inline-flex w-full items-center justify-center rounded-full border border-white/12 px-6 py-3 text-sm font-semibold text-white/85 transition hover:border-white/25 hover:bg-white/5 sm:w-auto"
        >
          Se deconnecter
        </button>
      </div>
    </div>

    <div class="mt-10 grid gap-8 xl:grid-cols-2">
      <article
        class="rounded-[24px] border border-white/10 bg-[#222b3b] p-6 md:p-8"
      >
        <h2 class="font-mono text-3xl font-bold text-white md:text-4xl">
          Gerer les artistes
        </h2>

        <p class="mt-4 text-sm leading-7 text-white/75">
          Selectionnez un artiste existant pour le modifier ou laissez l'option
          "Nouvel artiste" pour en creer un.
        </p>

        <form id="artistForm" class="mt-8 space-y-5">
          <div>
            <label
              for="artistSelect"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Artiste a modifier
            </label>
            <select
              id="artistSelect"
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            >
              <option value="">Nouvel artiste</option>
            </select>
          </div>

          <div>
            <label
              for="artistName"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Nom de l'artiste
            </label>
            <input
              id="artistName"
              name="nom_artiste"
              type="text"
              required
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            />
          </div>

          <div>
            <label
              for="artistGenre"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Genre musical
            </label>
            <input
              id="artistGenre"
              name="genre_musical"
              type="text"
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            />
          </div>

          <div>
            <label
              for="artistDescription"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Description
            </label>
            <textarea
              id="artistDescription"
              name="description"
              rows="5"
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            ></textarea>
          </div>

          <div>
            <label
              for="artistPhoto"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Photo principale
            </label>
            <input
              id="artistPhoto"
              name="photo_principale"
              type="file"
              accept="image/*"
              class="block w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-sm text-white file:mr-4 file:rounded-full file:border-0 file:bg-[#facc15] file:px-4 file:py-2 file:font-semibold file:text-black"
            />
          </div>

          <p
            id="artistMessage"
            class="hidden rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-sm"
          >
          </p>

          <div class="flex flex-wrap gap-4">
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center rounded-full bg-[#facc15] px-8 py-3.5 text-sm font-semibold text-black transition hover:opacity-90 sm:w-auto"
            >
              Enregistrer l'artiste
            </button>

            <button
              id="artistReset"
              type="button"
              class="inline-flex w-full items-center justify-center rounded-full border border-white/12 px-6 py-3 text-sm font-semibold text-white/85 transition hover:border-white/25 hover:bg-white/5 sm:w-auto"
            >
              Nouveau
            </button>
          </div>
        </form>
      </article>

      <article
        class="rounded-[24px] border border-white/10 bg-[#222b3b] p-6 md:p-8"
      >
        <h2 class="font-mono text-3xl font-bold text-white md:text-4xl">
          Gerer les scenes
        </h2>

        <p class="mt-4 text-sm leading-7 text-white/75">
          Selectionnez une scene existante pour la modifier ou laissez l'option
          "Nouvelle scene" pour en creer une.
        </p>

        <form id="sceneForm" class="mt-8 space-y-5">
          <div>
            <label
              for="sceneSelect"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Scene a modifier
            </label>
            <select
              id="sceneSelect"
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            >
              <option value="">Nouvelle scene</option>
            </select>
          </div>

          <div>
            <label
              for="sceneName"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Nom de la scene
            </label>
            <input
              id="sceneName"
              name="nom_scene"
              type="text"
              required
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            />
          </div>

          <div>
            <label
              for="sceneLocation"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Localisation
            </label>
            <input
              id="sceneLocation"
              name="localisation"
              type="text"
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            />
          </div>

          <div>
            <label
              for="sceneCapacity"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Capacite
            </label>
            <input
              id="sceneCapacity"
              name="capacite"
              type="number"
              min="0"
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            />
          </div>

          <div>
            <label
              for="sceneDescription"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Description
            </label>
            <textarea
              id="sceneDescription"
              name="description_scene"
              rows="5"
              class="w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-white outline-none transition focus:border-[#facc15]"
            ></textarea>
          </div>

          <div>
            <label
              for="scenePhoto"
              class="mb-2 block text-sm font-semibold text-white/85"
            >
              Photo de la scene
            </label>
            <input
              id="scenePhoto"
              name="photo_scene"
              type="file"
              accept="image/*"
              class="block w-full rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-sm text-white file:mr-4 file:rounded-full file:border-0 file:bg-[#facc15] file:px-4 file:py-2 file:font-semibold file:text-black"
            />
          </div>

          <p
            id="sceneMessage"
            class="hidden rounded-2xl border border-white/10 bg-[#1b2230] px-4 py-3 text-sm"
          >
          </p>

          <div class="flex flex-wrap gap-4">
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center rounded-full bg-[#facc15] px-8 py-3.5 text-sm font-semibold text-black transition hover:opacity-90 sm:w-auto"
            >
              Enregistrer la scene
            </button>

            <button
              id="sceneReset"
              type="button"
              class="inline-flex w-full items-center justify-center rounded-full border border-white/12 px-6 py-3 text-sm font-semibold text-white/85 transition hover:border-white/25 hover:bg-white/5 sm:w-auto"
            >
              Nouvelle
            </button>
          </div>
        </form>
      </article>
    </div>
  </section>

  <script type="module">
    import { pb } from "../lib/pocketbase.js";
    import { getArtists, getScenes, saveRecord } from "../lib/backend.mjs";

    const authStatus = document.getElementById("authStatus");
    const logoutButton = document.getElementById("logoutButton");

    const artistForm = document.getElementById("artistForm");
    const artistSelect = document.getElementById("artistSelect");
    const artistReset = document.getElementById("artistReset");
    const artistMessage = document.getElementById("artistMessage");

    const sceneForm = document.getElementById("sceneForm");
    const sceneSelect = document.getElementById("sceneSelect");
    const sceneReset = document.getElementById("sceneReset");
    const sceneMessage = document.getElementById("sceneMessage");

    let artists = [];
    let scenes = [];

    function setMessage(element, text, isError = false) {
      element.textContent = text;
      element.classList.remove(
        "hidden",
        "text-green-300",
        "text-red-300",
        "border-red-400/20",
        "border-green-400/20",
      );
      element.classList.add(isError ? "text-red-300" : "text-green-300");
      element.classList.add(
        isError ? "border-red-400/20" : "border-green-400/20",
      );
    }

    function resetArtistForm() {
      artistForm.reset();
      artistSelect.value = "";
    }

    function resetSceneForm() {
      sceneForm.reset();
      sceneSelect.value = "";
    }

    function fillArtistForm(id) {
      const artist = artists.find((item) => item.id === id);
      if (!artist) {
        resetArtistForm();
        return;
      }

      artistForm.nom_artiste.value = artist.nom_artiste || "";
      artistForm.genre_musical.value = artist.genre_musical || "";
      artistForm.description.value = artist.description || "";
      artistForm.photo_principale.value = "";
    }

    function fillSceneForm(id) {
      const scene = scenes.find((item) => item.id === id);
      if (!scene) {
        resetSceneForm();
        return;
      }

      sceneForm.nom_scene.value = scene.nom_scene || "";
      sceneForm.localisation.value = scene.localisation || "";
      sceneForm.capacite.value = scene.capacite || "";
      sceneForm.description_scene.value = scene.description_scene || "";
      sceneForm.photo_scene.value = "";
    }

    function renderArtistOptions() {
      const currentValue = artistSelect.value;
      artistSelect.innerHTML = '<option value="">Nouvel artiste</option>';

      artists.forEach((artist) => {
        const option = document.createElement("option");
        option.value = artist.id;
        option.textContent = artist.nom_artiste;
        artistSelect.append(option);
      });

      artistSelect.value = artists.some((item) => item.id === currentValue)
        ? currentValue
        : "";
    }

    function renderSceneOptions() {
      const currentValue = sceneSelect.value;
      sceneSelect.innerHTML = '<option value="">Nouvelle scene</option>';

      scenes.forEach((scene) => {
        const option = document.createElement("option");
        option.value = scene.id;
        option.textContent = scene.nom_scene;
        sceneSelect.append(option);
      });

      sceneSelect.value = scenes.some((item) => item.id === currentValue)
        ? currentValue
        : "";
    }

    async function refreshData() {
      [artists, scenes] = await Promise.all([getArtists(), getScenes()]);
      renderArtistOptions();
      renderSceneOptions();
    }

    async function initPage() {
      if (!pb.authStore.isValid) {
        window.location.href = "/login";
        return;
      }

      const currentUser = pb.authStore.model;
      authStatus.textContent = currentUser?.email
        ? `Connecte en tant que ${currentUser.email}`
        : "Connecte";

      await refreshData();
    }

    artistSelect?.addEventListener("change", (event) => {
      fillArtistForm(event.target.value);
    });

    sceneSelect?.addEventListener("change", (event) => {
      fillSceneForm(event.target.value);
    });

    artistReset?.addEventListener("click", resetArtistForm);
    sceneReset?.addEventListener("click", resetSceneForm);

    logoutButton?.addEventListener("click", () => {
      pb.authStore.clear();
      window.location.href = "/login";
    });

    artistForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const id = artistSelect.value || null;
      const formData = new FormData();
      formData.set("nom_artiste", artistForm.nom_artiste.value.trim());
      formData.set("genre_musical", artistForm.genre_musical.value.trim());
      formData.set("description", artistForm.description.value.trim());

      const photo = artistForm.photo_principale.files?.[0];
      if (photo) formData.set("photo_principale", photo);

      try {
        await saveRecord("artistes", formData, id);
        setMessage(
          artistMessage,
          id ? "Artiste modifie avec succes." : "Artiste ajoute avec succes.",
        );
        await refreshData();
        if (!id) resetArtistForm();
      } catch (error) {
        setMessage(artistMessage, "Impossible d'enregistrer l'artiste.", true);
      }
    });

    sceneForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const id = sceneSelect.value || null;
      const formData = new FormData();
      formData.set("nom_scene", sceneForm.nom_scene.value.trim());
      formData.set("localisation", sceneForm.localisation.value.trim());
      formData.set(
        "description_scene",
        sceneForm.description_scene.value.trim(),
      );

      const capacity = sceneForm.capacite.value.trim();
      if (capacity) formData.set("capacite", capacity);

      const photo = sceneForm.photo_scene.files?.[0];
      if (photo) formData.set("photo_scene", photo);

      try {
        await saveRecord("scenes", formData, id);
        setMessage(
          sceneMessage,
          id ? "Scene modifiee avec succes." : "Scene ajoutee avec succes.",
        );
        await refreshData();
        if (!id) resetSceneForm();
      } catch (error) {
        setMessage(sceneMessage, "Impossible d'enregistrer la scene.", true);
      }
    });

    initPage();
  </script>
</BaseLayout>
