---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Les Rives du Territoire",
  description = "Festival musical et culturel",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#1b2230] text-white antialiased">
    <Header />
    <main class="pt-[81px]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
