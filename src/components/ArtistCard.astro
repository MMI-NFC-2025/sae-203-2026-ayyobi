---
import PocketImage from "./PocketImage.astro";
import { formatDate, formatHour } from "../lib/utils.mjs";

const { item } = Astro.props;

const artiste = item.artiste || item;
const scene = item.scene || null;
const date = item.date_representation || null;
---

<a
  href={`/artistes/${artiste.id}`}
  class="group block overflow-hidden rounded-[24px] border border-white/10 bg-[#222b3b] transition duration-300 hover:-translate-y-1 hover:border-white/20"
>
  <PocketImage
    record={artiste}
    field="photo_principale"
    alt={artiste.nom_artiste}
    class="h-72 w-full object-cover"
  />

  <div class="space-y-3 p-5">
    <h2
      class="font-mono text-2xl font-bold text-white transition group-hover:text-[#facc15]"
    >
      {artiste.nom_artiste}
    </h2>

    {
      date && (
        <p class="text-sm text-white/70">
          {formatDate(date)} — {formatHour(date)}
        </p>
      )
    }

    {scene && <p class="text-sm text-white/70">{scene.nom_scene}</p>}

    {
      artiste.genre_musical && (
        <span class="inline-flex rounded-full bg-[#facc15] px-3 py-1 text-xs font-semibold text-black">
          {artiste.genre_musical}
        </span>
      )
    }
  </div>
</a>
