---
import PocketImage from "./PocketImage.astro";
import { formatDate, formatHour } from "../lib/utils.mjs";
import { slugify } from "../lib/utils.mjs";

const { item } = Astro.props;

const artiste = item.artiste || item;
const scene = item.scene || null;
const date = item.date_representation || null;
---

<a
  href={`/artistes/${slugify(artiste.nom_artiste)}`}
  class="group flex h-full flex-col overflow-hidden rounded-[24px] border border-white/10 bg-[#222b3b] transition duration-300 hover:-translate-y-1 hover:border-white/20"
>
  <PocketImage
    record={artiste}
    field="photo_principale"
    alt={artiste.nom_artiste}
    class="h-56 w-full object-cover sm:h-64 lg:h-72"
  />

  <div class="space-y-3 p-4 sm:p-5">
    <h2
      class="font-mono text-xl font-bold text-white transition group-hover:text-[#facc15] sm:text-2xl"
    >
      {artiste.nom_artiste}
    </h2>

    {
      date && (
        <p class="text-xs text-white/70 sm:text-sm">
          {formatDate(date)} — {formatHour(date)}
        </p>
      )
    }

    {scene && <p class="text-xs text-white/70 sm:text-sm">{scene.nom_scene}</p>}

    {
      artiste.genre_musical && (
        <span class="inline-flex rounded-full bg-[#facc15] px-3 py-1 text-[11px] font-semibold text-black sm:text-xs">
          {artiste.genre_musical}
        </span>
      )
    }
  </div>
</a>
