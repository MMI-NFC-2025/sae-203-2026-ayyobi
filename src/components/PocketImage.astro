---
import { getFileUrl } from "../lib/backend.mjs";

const { record, field, alt = "", class: className = "" } = Astro.props;

const imageUrl = record ? getFileUrl(record, field) : null;
---

{
  imageUrl ? (
    <img src={imageUrl} alt={alt} class={className} loading="lazy" />
  ) : (
    <div
      class={`flex items-center justify-center bg-white/5 text-sm text-white/50 ${className}`}
    >
      Image indisponible
    </div>
  )
}
