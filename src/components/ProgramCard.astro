---
import { formatHour, formatDate } from "../lib/utils.mjs";

const { item } = Astro.props;

const artiste = item.expand?.artiste || item.artiste || null;
const scene = item.expand?.scene || item.scene || null;
---

<article
  class="rounded-[22px] border border-white/10 bg-[#222b3b] p-5 transition hover:border-white/20"
>
  <div class="grid gap-4 md:grid-cols-[110px_1fr] md:items-start">
    <div class="font-mono text-2xl font-bold text-[#facc15]">
      {formatHour(item.date_representation)}
    </div>

    <div class="space-y-2">
      <h3 class="font-mono text-xl font-bold text-white">
        {artiste?.nom_artiste || "Artiste"}
      </h3>

      <p class="text-sm text-white/70">
        {scene?.nom_scene || "Scène non définie"}
      </p>

      <p class="text-sm text-white/60">
        {formatDate(item.date_representation)}
      </p>

      {
        artiste?.genre_musical && (
          <span class="inline-flex rounded-full bg-[#facc15] px-3 py-1 text-xs font-semibold text-black">
            {artiste.genre_musical}
          </span>
        )
      }
    </div>
  </div>
</article>
