---
import { formatHour, formatDate } from "../lib/utils.mjs";

const { item } = Astro.props;

const artiste = item.expand?.artiste || item.artiste || null;
const scene = item.expand?.scene || item.scene || null;
---

<article
  class="rounded-[22px] border border-white/10 bg-[#222b3b] p-4 transition hover:border-white/20 sm:p-5"
>
  <div class="grid gap-4 sm:grid-cols-[120px_1fr] sm:items-start">
    <div
      class="font-mono text-2xl font-bold text-[#facc15] text-center sm:text-left"
    >
      {formatHour(item.date_representation)}
    </div>

    <div class="space-y-2">
      <h3 class="font-mono text-lg font-bold text-white sm:text-xl">
        {artiste?.nom_artiste || "Artiste"}
      </h3>

      <p class="text-xs text-white/70 sm:text-sm">
        {scene?.nom_scene || "Scène non définie"}
      </p>

      <p class="text-xs text-white/60 sm:text-sm">
        {formatDate(item.date_representation)}
      </p>

      {
        artiste?.genre_musical && (
          <span class="inline-flex rounded-full bg-[#facc15] px-3 py-1 text-[11px] font-semibold text-black sm:text-xs">
            {artiste.genre_musical}
          </span>
        )
      }
    </div>
  </div>
</article>
