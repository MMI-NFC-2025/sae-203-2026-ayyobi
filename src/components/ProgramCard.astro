---
import PocketImage from './PocketImage.astro';
import { formatDateFr } from '../lib/utils.mjs';

const { item } = Astro.props;
const artist = item?.artiste;
const scene = item?.scene;
---

<article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="grid gap-4 md:grid-cols-[120px_1fr_180px] md:items-center">
    <div class="overflow-hidden rounded-2xl bg-slate-100">
      <PocketImage src={artist?.photo} alt={artist?.nom || 'Artiste'} className="aspect-square" />
    </div>
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
        {item?.jourLabel || 'Programme'}
      </p>
      <h3 class="mt-2 text-xl font-bold text-slate-950">{artist?.nom || 'Artiste a venir'}</h3>
      <p class="mt-1 text-sm text-slate-600">{artist?.genre || 'Genre non renseigne'}</p>
      <p class="mt-3 text-sm text-slate-500">
        {formatDateFr(item?.date)} {item?.heureDebut ? `• ${item.heureDebut}` : ''}
      </p>
    </div>
    <div class="text-sm text-slate-600 md:text-right">
      <p class="font-semibold text-slate-900">{scene?.nom || 'Scene a confirmer'}</p>
      {artist?.id && <a href={`/artistes/${artist.id}`} class="mt-3 inline-block font-semibold text-amber-600">Voir l'artiste</a>}
    </div>
  </div>
</article>
