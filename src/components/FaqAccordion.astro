---
const { items = [] } = Astro.props;
---

<div class="space-y-4">
  {
    items.map((item, index) => (
      <details class="group rounded-[20px] border border-white/10 bg-[#222b3b] p-5">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
          <span class="text-base font-semibold text-white">
            {item.question}
          </span>

          <span class="text-xl font-bold text-[#facc15] transition group-open:rotate-45">
            +
          </span>
        </summary>

        <div class="pt-4 text-sm leading-7 text-white/75">{item.reponse}</div>
      </details>
    ))
  }
</div>
