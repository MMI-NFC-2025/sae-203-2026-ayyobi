---
const { items = [] } = Astro.props;
---

<div class="grid gap-4">
  {items.map((item) => (
    <details class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <summary class="cursor-pointer list-none text-lg font-semibold text-slate-950">
        {item.question}
      </summary>
      <p class="mt-4 text-sm leading-7 text-slate-600">{item.reponse}</p>
    </details>
  ))}
</div>
