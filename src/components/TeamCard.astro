---
import PocketImage from "./PocketImage.astro";

const { member } = Astro.props;
---

<article
  class="group overflow-hidden rounded-[24px] border border-white/10 bg-[#222b3b] transition duration-300 hover:-translate-y-1 hover:border-white/20"
>
  <PocketImage
    record={member}
    field="photo"
    alt={member.nom}
    class="h-72 w-full object-cover object-top"
  />

  <div class="space-y-3 p-5">
    <h3
      class="font-mono text-2xl font-bold text-white transition group-hover:text-[#facc15]"
    >
      {member.nom}
    </h3>

    <p class="text-sm font-semibold text-[#facc15]">
      {member.role}
    </p>

    <p class="line-clamp-4 text-sm leading-6 text-white/70">
      {member.description}
    </p>
  </div>
</article>
