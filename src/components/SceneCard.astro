---
import PocketImage from "./PocketImage.astro";
import { slugify } from "../lib/utils.mjs";

const { scene } = Astro.props;
---

<a
  href={`/scenes/${slugify(scene.nom_scene)}`}
  class="group flex h-full flex-col overflow-hidden rounded-[24px] border border-white/10 bg-[#222b3b] transition duration-300 hover:-translate-y-1 hover:border-white/20"
>
  <PocketImage
    record={scene}
    field="photo_scene"
    alt={scene.nom_scene}
    class="h-56 w-full object-cover sm:h-64 lg:h-72"
  />

  <div class="space-y-3 p-4 sm:p-5">
    <h2
      class="font-mono text-xl font-bold text-white transition group-hover:text-[#facc15] sm:text-2xl"
    >
      {scene.nom_scene}
    </h2>

    {
      scene.description_scene && (
        <p class="line-clamp-3 text-xs leading-6 text-white/70 sm:text-sm">
          {scene.description_scene}
        </p>
      )
    }

    {
      scene.capacite && (
        <span class="inline-flex rounded-full bg-[#facc15] px-4 py-1.5 text-[11px] font-semibold text-black sm:text-sm">
          Capacité : {scene.capacite} personnes
        </span>
      )
    }
  </div>
</a>
