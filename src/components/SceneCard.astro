---
import PocketImage from "./PocketImage.astro";

const { scene } = Astro.props;
---

<a
  href={`/scenes/${scene.id}`}
  class="group block overflow-hidden rounded-[24px] border border-white/10 bg-[#222b3b] transition duration-300 hover:-translate-y-1 hover:border-white/20"
>
  <PocketImage
    record={scene}
    field="photo_scene"
    alt={scene.nom_scene}
    class="h-72 w-full object-cover"
  />

  <div class="space-y-3 p-5">
    <h2
      class="font-mono text-2xl font-bold text-white transition group-hover:text-[#facc15]"
    >
      {scene.nom_scene}
    </h2>

    {
      scene.description_scene && (
        <p class="line-clamp-3 text-sm leading-6 text-white/70">
          {scene.description_scene}
        </p>
      )
    }

    {
      scene.capacite && (
        <span class="inline-flex rounded-full bg-[#facc15] px-4 py-1.5 text-sm font-semibold text-black">
          Capacité : {scene.capacite} personnes
        </span>
      )
    }
  </div>
</a>
