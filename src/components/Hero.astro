---
const {
  title,
  subtitle,
  ctaHref = '/programme',
  ctaLabel = 'Voir le programme',
} = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-4 py-16 md:py-24">
  <div class="rounded-[2rem] bg-slate-950 px-6 py-12 text-white md:px-10">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-300">Edition 2026</p>
    <h1 class="mt-4 text-4xl font-black tracking-tight md:text-6xl">{title}</h1>
    <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 md:text-lg">{subtitle}</p>
    <a href={ctaHref} class="mt-8 inline-flex rounded-full bg-amber-400 px-6 py-3 text-sm font-bold text-slate-950">
      {ctaLabel}
    </a>
  </div>
</section>
