---
const {
  title,
  subtitle,
  buttonText,
  buttonHref = "#",
  image,
  dates = [],
} = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <img
    src={image}
    alt={title}
    class="absolute inset-0 -z-10 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-[#1b2230]/55"></div>

  <div class="mx-auto max-w-7xl px-4 py-16 md:px-6 md:py-24 lg:py-28">
    <div class="max-w-3xl">
      <h1
        class="font-mono text-5xl font-bold leading-none text-white md:text-7xl"
      >
        {title}
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/85 md:text-2xl">
        {subtitle}
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={buttonHref}
          class="inline-flex items-center justify-center rounded-full bg-[#facc15] px-8 py-4 text-base font-semibold text-black transition hover:opacity-90"
        >
          {buttonText}
        </a>
      </div>
    </div>

    {
      dates.length > 0 && (
        <div class="mt-12 grid gap-4 sm:grid-cols-2 xl:max-w-4xl">
          {dates.map((item) => (
            <article class="rounded-[22px] border border-white/15 bg-[#1b2230]/60 p-5 backdrop-blur-sm">
              <h2 class="font-mono text-xl font-bold text-[#facc15]">
                {item.day}
              </h2>
              <p class="mt-2 text-sm text-white/80">{item.text}</p>
            </article>
          ))}
        </div>
      )
    }
  </div>
</section>
