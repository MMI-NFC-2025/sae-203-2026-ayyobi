---
const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/festival", label: "Le Festival" },
  { href: "/programme", label: "Programme" },
  { href: "/artistes", label: "Artistes" },
  { href: "/scenes", label: "Scènes" },
  { href: "/infos-pratiques", label: "Info pratique" },
  { href: "/contact", label: "Contact" },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-[#1b2230]/95 backdrop-blur-md"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:px-6 md:py-4"
  >
    <a href="/" aria-label="Accueil" class="shrink-0">
      <img
        src="/images/logo.svg"
        alt="Les Rives du Territoire"
        class="h-10 w-auto md:h-14"
      />
    </a>

    <nav class="hidden md:block" aria-label="Navigation principale">
      <ul class="flex items-center gap-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="relative inline-block py-2 text-sm font-medium text-white/85 transition hover:text-white after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-[#facc15] after:transition-transform after:duration-300 hover:after:scale-x-100"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      id="menu-toggle"
      type="button"
      aria-label="Ouvrir le menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="relative z-[70] flex h-10 w-10 flex-col items-center justify-center gap-[6px] md:hidden"
    >
      <span class="block h-[2px] w-7 bg-white transition-all duration-300"
      ></span>
      <span class="block h-[2px] w-7 bg-white transition-all duration-300"
      ></span>
      <span class="block h-[2px] w-7 bg-white transition-all duration-300"
      ></span>
    </button>
  </div>
</header>

<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-[60] h-screen w-screen overflow-hidden bg-[#1b2230] opacity-0 transition-all duration-300 md:hidden"
  aria-hidden="true"
>
  <div class="flex h-full flex-col overflow-hidden">
    <div
      class="flex items-center justify-between border-b border-white/10 px-4 py-4"
    >
      <a href="/" aria-label="Accueil" class="shrink-0">
        <img
          src="/images/logo.svg"
          alt="Les Rives du Territoire"
          class="h-12 w-auto"
        />
      </a>

      <button
        id="menu-close"
        type="button"
        aria-label="Fermer le menu"
        class="relative flex h-10 w-10 items-center justify-center"
      >
        <span class="absolute block h-[2px] w-8 rotate-45 bg-white"></span>
        <span class="absolute block h-[2px] w-8 -rotate-45 bg-white"></span>
      </button>
    </div>

    <nav
      class="flex flex-1 items-center justify-center overflow-hidden px-6"
      aria-label="Navigation mobile"
    >
      <ul class="flex flex-col items-center gap-10 text-center">
        {
          navLinks.map((link, index) => (
            <li
              class="mobile-link translate-y-4 opacity-0 transition-all duration-500"
              style={`transition-delay: ${100 + index * 70}ms;`}
            >
              <a
                href={link.href}
                class="font-mono text-[2.2rem] font-bold leading-none tracking-[0.02em] text-white transition hover:text-[#facc15] sm:text-[2.8rem]"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuClose = document.getElementById("menu-close");
  const mobileLinks = mobileMenu?.querySelectorAll(".mobile-link");
  const burgerLines = menuToggle?.querySelectorAll("span");

  function openMenu() {
    if (!menuToggle || !mobileMenu) return;

    menuToggle.setAttribute("aria-expanded", "true");
    mobileMenu.setAttribute("aria-hidden", "false");
    mobileMenu.classList.remove("pointer-events-none", "opacity-0");
    mobileMenu.classList.add("pointer-events-auto", "opacity-100");
    document.documentElement.classList.add("overflow-hidden");
    document.body.classList.add("overflow-hidden", "touch-none");

    mobileLinks?.forEach((item) => {
      item.classList.remove("translate-y-4", "opacity-0");
      item.classList.add("translate-y-0", "opacity-100");
    });

    if (burgerLines?.length === 3) {
      burgerLines[0].classList.add("translate-y-[8px]", "rotate-45");
      burgerLines[1].classList.add("opacity-0");
      burgerLines[2].classList.add("-translate-y-[8px]", "-rotate-45");
    }
  }

  function closeMenu() {
    if (!menuToggle || !mobileMenu) return;

    menuToggle.setAttribute("aria-expanded", "false");
    mobileMenu.setAttribute("aria-hidden", "true");
    mobileMenu.classList.remove("pointer-events-auto", "opacity-100");
    mobileMenu.classList.add("pointer-events-none", "opacity-0");
    document.documentElement.classList.remove("overflow-hidden");
    document.body.classList.remove("overflow-hidden", "touch-none");

    mobileLinks?.forEach((item) => {
      item.classList.add("translate-y-4", "opacity-0");
      item.classList.remove("translate-y-0", "opacity-100");
    });

    if (burgerLines?.length === 3) {
      burgerLines[0].classList.remove("translate-y-[8px]", "rotate-45");
      burgerLines[1].classList.remove("opacity-0");
      burgerLines[2].classList.remove("-translate-y-[8px]", "-rotate-45");
    }
  }

  menuToggle?.addEventListener("click", () => {
    const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  menuClose?.addEventListener("click", closeMenu);

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeMenu();
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) closeMenu();
  });
</script>
